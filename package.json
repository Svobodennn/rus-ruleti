{
  "name": "rus-ruleti",
  "version": "1.0.1",
  "description": "Rus Ruleti — Şaka oyunu (Electron). Joke app: simulates OS destruction with zero real system operations.",
  "private": true,
  "main": "out/main/index.js",
  "author": "famelink",
  "homepage": "https://famelink.ai",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "build:mac": "npm run build && electron-builder --mac --config electron-builder.yml",
    "build:win": "npm run build && electron-builder --win --config electron-builder.yml",
    "build:linux": "npm run build && electron-builder --linux --config electron-builder.yml",
    "build:dryrun": "npm run build && electron-builder --dir --config electron-builder.yml",
    "build:all": "npm run build && electron-builder --mac --win --linux --config electron-builder.yml",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.preload.json && tsc --noEmit -p tsconfig.renderer.json",
    "lint": "eslint . --ext .ts --max-warnings 0",
    "start": "electron-vite preview",
    "test:e2e": "playwright test",
    "test:e2e:update-snapshots": "playwright test --update-snapshots"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/howler": "^2.2.13",
    "@types/node": "^20.14.0",
    "@types/three": "^0.184.1",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "electron": "^30.1.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.2.0",
    "eslint": "^8.57.0",
    "playwright": "^1.60.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.0"
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "howler": "^2.2.4",
    "postprocessing": "^6.39.1",
    "three": "^0.184.0"
  }
}
